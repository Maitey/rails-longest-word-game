<div class="container mt-5 text-center">
  <h1>Longest Word Game</h1>

  <div class="letters my-4">
    <% @letters.each do |letter| %>
      <span class="letter"><%= letter %></span>
    <% end %>
  </div>

  <form action="/score" method="post" data-turbo="false">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

    <input type="hidden" name="letters" value="<%= @letters.join(" ") %>">

    <input type="text" name="word" class="form-control mb-3">

    <input type="submit" value="Play" class="btn btn-primary">
  </form>
</div>
